; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but feel free to add to the end of the file.

config_version=5

[application]

config/name="Cult Rising"
config/description="A top-down GTA1/2 style cult management game"
run/main_scene="res://scenes/World.tscn"
config/features=PackedStringArray("4.2", "C#")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/GameManager.cs"
HeatSystem="*res://scripts/HeatSystem.cs"
InnerCircle="*res://scripts/InnerCircle.cs"
StorySystem="*res://scripts/StorySystem.cs"
MissionSystem="*res://scripts/MissionSystem.cs"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[dotnet]

project/assembly_name="CultRising"

[editor_plugins]

enabled=PackedStringArray()

